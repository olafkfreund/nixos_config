themes/gruvbox-material-gtk/

# Build results
result
result-*

# MkDocs build output (site is built reproducibly via `nix build .#docs`)
site/
public/

# Temporary files
.tmp/
*.tmp

# direnv cache + atomic-swap temp dirs.
# direnv writes .direnv.tmp-<suffix>/ while rebuilding the cache, then renames
# it over .direnv/. Without ignoring it, scripts/update-commit-deploy.sh's
# pre-flight dirty-tree check (`git status --porcelain | awk '$2 != "flake.lock"'`)
# trips and aborts.
.direnv/
.direnv.tmp-*/

# Editor files
.vscode/
*.swp
*.swo
*~

# Claude Code runtime artifacts (the .claude/ tree itself is tracked,
# but ScheduleWakeup writes a transient JSON lockfile here that must not be
# committed — otherwise nhs/update-commit-deploy aborts on dirty tree.)
.claude/scheduled_tasks.lock
.claude/*.lock

# aifactory / agent tooling local state (contains .env with secrets,
# PR scratch state, and spec drafts — must never be committed)
.aifactory/

# antigravity CLI local state (UUID-named JSON cache files)
.antigravitycli/

# Throwaway local experiments — never ship
scratch/

# OS generated files
.DS_Store
Thumbs.db

# Secrets management - plaintext secrets only
# Note: .age files (encrypted) should be committed, plaintext should not
pkgs/microsoft-defender-for-endpoint/mdatp.deb
